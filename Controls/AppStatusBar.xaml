<UserControl x:Class="AIWorkspace.Controls.AppStatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:AIWorkspace.ViewModels">

    <UserControl.DataContext>
        <viewModels:StatusBarViewModel/>
    </UserControl.DataContext>

    <Border Height="32"
            Background="{DynamicResource SidebarBrush}"
            BorderBrush="#303030"
            BorderThickness="0,1,0,0">

        <Grid Margin="12,0">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>

                <ColumnDefinition Width="Auto"/>

            </Grid.ColumnDefinitions>

            <!-- Status -->

            <TextBlock
                Text="{Binding Status}"
                VerticalAlignment="Center"/>

            <!-- Provider -->

            <TextBlock
                Grid.Column="2"
                Text="{Binding Provider}"
                VerticalAlignment="Center"/>

            <!-- Model -->

            <TextBlock
                Grid.Column="4"
                Text="{Binding Model}"
                VerticalAlignment="Center"/>

            <!-- Version -->

            <TextBlock
                Grid.Column="7"
                Text="{Binding Version}"
                VerticalAlignment="Center"/>

            <!-- Chats -->

            <TextBlock
                Grid.Column="9"
                Text="{Binding ChatCount}"
                VerticalAlignment="Center"/>

        </Grid>

    </Border>

</UserControl>