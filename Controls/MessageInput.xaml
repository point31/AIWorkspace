<UserControl x:Class="AIWorkspace.Controls.MessageInput"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Margin="16,10,16,16"
            Padding="12,8"
            CornerRadius="16"
            Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Rounded prompt input -->
            <Border Grid.Column="0"
                    CornerRadius="12"
                    Background="#161B20"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Margin="0,0,10,0">
                <TextBox Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="40"
                         MaxHeight="160"
                         Padding="12,10"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         AcceptsReturn="False"
                         VerticalContentAlignment="Center"
                         Foreground="{DynamicResource TextBrush}"
                         CaretBrush="{DynamicResource TextBrush}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return"
                                    Command="{Binding SendMessageCommand}"/>
                    </TextBox.InputBindings>
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <ScrollViewer x:Name="PART_ContentHost"
                                                      Padding="{TemplateBinding Padding}"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Border>

            <!-- Send button -->
            <Button Grid.Column="1"
                    Width="80"
                    Height="40"
                    Content="Send ↑"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding SendMessageCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</UserControl>
