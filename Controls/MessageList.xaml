<UserControl x:Class="AIWorkspace.Controls.MessageList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:AIWorkspace.ViewModels">

   

    <Grid>

        <ListBox
            ItemsSource="{Binding Messages}"
            BorderThickness="0"
            Background="Transparent">

            <ListBox.ItemTemplate>

                <DataTemplate>

                    <Border Margin="12"
                            Padding="14"
                            CornerRadius="12"
                            MaxWidth="700">

                        <TextBlock
                            Text="{Binding Content}"
                            TextWrapping="Wrap"/>

                    </Border>

                </DataTemplate>

            </ListBox.ItemTemplate>

        </ListBox>

    </Grid>

</UserControl>