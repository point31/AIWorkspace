<UserControl x:Class="AIWorkspace.Controls.NavigationMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AIWorkspace.Controls"
             xmlns:viewModels="clr-namespace:AIWorkspace.ViewModels">

    <UserControl.DataContext>
        <viewModels:NavigationMenuViewModel/>
    </UserControl.DataContext>

    <Border Background="{DynamicResource SidebarBrush}">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo -->

            <StackPanel Margin="20">

                <Ellipse Width="48"
                         Height="48"
                         Fill="{DynamicResource PrimaryBrush}"/>

                <TextBlock Text="AI Workspace"
                           Margin="0,15,0,20"
                           FontWeight="Bold"
                           FontSize="22"
                           Foreground="{DynamicResource TextBrush}"/>

            </StackPanel>

            <!-- Navigation -->

            <ListBox Grid.Row="1"
         ItemsSource="{Binding Items}"
         SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
         Background="Transparent"
         BorderThickness="0">

                <ListBox.ItemTemplate>

                    <DataTemplate>

                        <controls:NavigationItem/>

                    </DataTemplate>

                </ListBox.ItemTemplate>

            </ListBox>

            <!-- User -->

            <Border Grid.Row="2"
                    Margin="15"
                    Padding="12"
                    CornerRadius="10"
                    Background="{DynamicResource CardBrush}">

                <TextBlock
                    Text="Not signed in"
                    Foreground="{DynamicResource SecondaryTextBrush}"/>

            </Border>

        </Grid>

    </Border>

</UserControl>