<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Main Colors -->

    <SolidColorBrush x:Key="WindowBackgroundBrush"
                     Color="#101417"/>

    <SolidColorBrush x:Key="SidebarBrush"
                     Color="#171B20"/>

    <SolidColorBrush x:Key="CardBrush"
                     Color="#20252B"/>

    <SolidColorBrush x:Key="PrimaryBrush"
                     Color="#2E7D32"/>

    <SolidColorBrush x:Key="PrimaryHoverBrush"
                     Color="#3FA246"/>

    <SolidColorBrush x:Key="BorderBrush"
                     Color="#2B3138"/>

    <SolidColorBrush x:Key="TextBrush"
                     Color="White"/>

    <SolidColorBrush x:Key="SecondaryTextBrush"
                     Color="#B4BDC8"/>

</ResourceDictionary>